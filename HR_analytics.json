{
  "name": "HR Dark Professional Theme",
  "dataColors": [
    "#22D3EE",
    "#1D4ED8",
    "#A78BFA",
    "#4ADE80",
    "#F87171",
    "#FACC15",
    "#F59E0B",
    "#60A5FA"
  ],
  "background": "#0F172A",
  "foreground": "#F8FAFC",
  "tableAccent": "#22D3EE",

  "visualStyles": {
    "*": {
      "*": {
        "color": [{ "solid": { "color": "#F8FAFC" } }],
        "fontFamily": "Segoe UI"
      },
      "title": [
        {
          "show": true,
          "color": { "solid": { "color": "#F8FAFC" } },
          "fontSize": 14,
          "fontFamily": "Segoe UI Semibold"
        }
      ],
      "background": [
        {
          "show": true,
          "color": { "solid": { "color": "#1E293B" } },
          "transparency": 0
        }
      ],
      "border": [
        {
          "show": false
        }
      ]
    },

    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#94A3B8" } },
            "fontSize": 12
          }
        ],
        "calloutValue": [
          {
            "color": { "solid": { "color": "#22D3EE" } },
            "fontSize": 28
          }
        ]
      }
    },

    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridHorizontal": true,
            "outlineColor": { "solid": { "color": "#334155" } }
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "color": { "solid": { "color": "#F8FAFC" } },
            "background": { "solid": { "color": "#1D4ED8" } }
          }
        ],
        "values": [
          {
            "color": { "solid": { "color": "#E2E8F0" } },
            "background": { "solid": { "color": "#1E293B" } }
          }
        ]
      }
    },

    "matrix": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridHorizontal": true,
            "outlineColor": { "solid": { "color": "#334155" } }
          }
        ],
        "rowHeaders": [
          {
            "color": { "solid": { "color": "#F8FAFC" } }
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "items": [
          {
            "color": { "solid": { "color": "#F8FAFC" } },
            "background": { "solid": { "color": "#1E293B" } }
          }
        ],
        "selection": [
          {
            "color": { "solid": { "color": "#22D3EE" } }
          }
        ]
      }
    }
  }
}